# RAG Parser Module Configuration
# Copy to .env and fill in your values

PARSER_DEFAULT_STRATEGY=auto

# Cloud OCR provider selection: mistral | llamaparse
PARSER_OCR_CLOUD_PROVIDER=mistral

# Mistral OCR
MISTRAL_API_KEY=

# LlamaParse
LLAMAPARSE_API_KEY=
LLAMAPARSE_ENDPOINT=https://api.cloud.llamaindex.ai
LLAMAPARSE_RESULT_TYPE=markdown
LLAMAPARSE_POLL_INTERVAL_SECONDS=5
LLAMAPARSE_TIMEOUT_SECONDS=120

# Local OCR engine: tesseract | paddleocr
PARSER_OCR_LOCAL_ENGINE=tesseract
PARSER_OCR_LOCAL_LANGUAGE=eng

# Fallback chain: comma-separated strategy names tried in order
PARSER_FALLBACK_CHAIN=docling,ocr_cloud,ocr_local

# If extracted text ratio per page < this, treat PDF as scanned
PARSER_SCANNED_TEXT_THRESHOLD=0.05

# Debug output directory
PARSER_DEBUG_DIR=./debug_output
PARSER_ENABLE_DEBUG=true

# Logging
LOG_LEVEL=INFO
